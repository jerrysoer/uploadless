# Uploadless Environment Variables
# Copy to .env.local and fill in values

# --- Required for Supabase features ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Required for /dashboard auth ---
AUTH_USER=
AUTH_PASSWORD=

# --- Required for production (IP hashing) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
IP_HASH_SALT=

# --- Required for analytics cron aggregation ---
CRON_SECRET=
